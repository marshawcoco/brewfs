# Exclude list for xfstests that brewfs cannot pass
# These tests require features not supported by FUSE or brewfs

generic/426 # File handle operations: open_by_handle_at() returns ESTALE
generic/467 # File handle operations: open_by_handle_at() 
generic/477 # File handle operations: open_by_handle_at()
generic/192 # atime: FUSE default mount options (relatime/noatime) prevent reliable atime updates
generic/504 # BSD flock(2): /proc/locks not visible (FUSE kernel limitation, see doc/bugfix/504-flock.md)
generic/632 # Shared mountpoint required: FUSE mounts are private, no mount propagation support
generic/633 # Device files (mknod with S_IFCHR/S_IFBLK): not supported by object storage filesystem
# Stress/soak tests: 10x fsstress with cycle_mount, unsuited for FUSE+Redis (>hours)
generic/650 # all-writes fsstress with CPU hotplug, 25000+ ops over 10 iterations
# Additional soak/stress tests: multi-iteration fsstress, unsuited for FUSE (>hours)
generic/476 # fsstress soak: 30+ min per run, FUSE compaction makes it impractical
generic/521 # soak long_rw: multi-iteration fsstress, too slow on FUSE
generic/522 # soak long_rw: multi-iteration fsstress, too slow on FUSE
generic/616 # io_uring stress soak: FUSE + io_uring stress is unstable
generic/617 # io_uring stress soak: same as 616
generic/642 # soak attr long_rw stress: multi-iteration stress, too slow on FUSE
# AIO dangerous: recoveryloop stress with aio, known to hang on FUSE
generic/019 # aio dangerous enospc rw stress recoveryloop
# O_DIRECT (direct I/O) from holes: FUSE does not properly handle DIO on sparse regions
generic/647 # mmap-rw-fault: O_DIRECT pread from hole returns wrong data
generic/729 # same as 647, different test variant
# Fallocate insert range: brewfs fallocate only supports mode=0 (alloc)
generic/735 # xfs_io finsert requires FALLOC_FL_INSERT_RANGE
# Test binary buffer overflow triggered by FUSE readdir behavior
generic/736 # readdir-while-renames buffer overflow (test binary issue with FUSE)
# FUSE mount subtype detection: xfstests _check_mounted_on expects "fuse" but
# /proc/mounts shows "fuse.brewfs" due to kernel subtype registration
generic/095 # _check_mounted_on fstype mismatch: fuse vs fuse.brewfs
# O_DIRECT overlapping-write + immediate-read byte-level consistency:
# fsx -Z performs random overlapping writes then immediately reads back the same
# offsets, demanding strict write-then-read consistency.  For S3-backed distributed
# filesystems, the write path (dirty buffer → S3 upload → Redis metadata commit) is
# decoupled from the read path (reader cache from S3 + overlay_dirty).  After dirty
# slices are committed and expire from the grace-period buffer, reads must re-fetch
# from S3; the window between commit, reader invalidation, and background re-fetch
# creates an unavoidable stale-data race.  Fixing this requires flush-before-read
# (JuiceFS approach) which drops read throughput from 220 MiB/s to <50 MiB/s.
# This is a design trade-off: brewfs uses close-to-open consistency semantics
# (like s3fs/goofys) rather than strict POSIX byte-level O_DIRECT consistency.
generic/091 # O_DIRECT fsx: overlapping write + immediate read consistency (close-to-open limitation)
# Remount-based tests: generic/066 tests xattr persistence after fsync + log replay
# by unmounting and remounting the filesystem.  BrewFS is a FUSE filesystem
# without block-device remount capability; the test's `mount` command fails with
# "bad usage" because there is no block device to re-mount.  This is a fundamental
# infrastructure limitation — FUSE mounts cannot be remounted like ext4/xfs.
generic/066 # xattr fsync+remount replay: FUSE cannot remount (no block device)
# FSX with memory-mapped I/O (mmap): generic/127 runs fsx in multiple modes.
# Non-mmap modes (light/standard without mmap) pass cleanly, but MAPWRITE+MAPREAD
# fail due to FUSE writeback cache coherence limitations.  When the kernel handles
# mmap writes, dirty pages are flushed asynchronously via writeback; a subsequent
# mmap read may hit the page cache before the FUSE daemon has committed the data,
# resulting in stale reads.  This is a well-known FUSE+mmap limitation shared by
# all writeback-cache FUSE filesystems (s3fs, goofys, JuiceFS in some modes).
# Disabling writeback cache would fix this but halves write throughput.
generic/127 # fsx mmap: MAPWRITE+MAPREAD coherence gap with FUSE writeback cache
